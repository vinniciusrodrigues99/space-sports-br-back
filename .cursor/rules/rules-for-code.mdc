    [FromQuery] string? pesquisaGeral,
    [FromQuery] List<Guid>? idsEmpresas,
    [FromQuery] bool? ativo,
    [FromQuery] string? sortBy,  // Frontend sends: [{"campo":"nomeEmpresa","valor":"ASC"}]
    [FromQuery] int page = 1,
