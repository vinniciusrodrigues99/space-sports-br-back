<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="modalgr-hub" value="https://pkgs.dev.azure.com/modalgr-hub/_packaging/modalgr-hub/nuget/v3/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!-- Credentials are not stored here. Configure locally via:
       dotnet nuget update source modalgr-hub -u AzureDevops -p <YOUR_PAT> - -store-password-in-clear-text
       Or set NUGET_CREDENTIALPROVIDER_SESSIONTOKENCACHE_ENABLED=true with Azure Artifacts Credential Provider -->

</configuration>