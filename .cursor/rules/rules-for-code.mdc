**Handler with Deserialization:**
```csharp
public async Task<ResponseBase<GetEmpresasByFiltersQueryResponse>> Handle(
    GetEmpresasByFiltersQuery request,
    CancellationToken cancellationToken)
{
    // Deserialize JSON string to List<SortBy>
    List<SortBy> sortByList = JsonUtils.DeserializeSortBy(request.SortBy);
    
    var result = await _empresaRepository.BuscarEmpresasPorFiltrosAsync(
        request.PesquisaGeral,
        request.IdsEmpresas,
        request.Ativo,
        sortByList,
        request.Page,
        request.PageSize,
        cancellationToken);
    
    var paginatedList = (PaginatedList<EmpresaListDTO>)result;
    
    return ResponseBase<GetEmpresasByFiltersQueryResponse>.Success(
        new GetEmpresasByFiltersQueryResponse { Empresas = paginatedList });
}
```

**Repository with Dynamic SQL:**
```csharp
public async Task<object> BuscarEmpresasPorFiltrosAsync(
    string? pesquisaGeral,
    List<Guid>? ids,
    bool? ativo,
    List<SortBy>? sortBy,
    int page,
    int pageSize,
    CancellationToken cancellationToken = default)
{
    var connection = CreateConnection();
    var sql = "SELECT ID, NOME, STATUS FROM T_EMPRESA WHERE 1=1";
    var parameters = new DynamicParameters();
    
    // Dynamic filters
    if (!string.IsNullOrEmpty(pesquisaGeral))
    {
        sql += " AND (NOME LIKE @PesquisaGeral)";
        parameters.Add("PesquisaGeral", $"%{pesquisaGeral}%");
    }
    
    if (ids != null && ids.Any())
    {
        sql += " AND ID IN @Ids";
        parameters.Add("Ids", ids);
    }
    
    // Dynamic sorting
    var camposPermitidos = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        {"nome", "NOME"},
        {"status", "STATUS"}
    };
    
    if (sortBy != null && sortBy.Count > 0)
    {
        var validSorts = sortBy
            .Where(s => camposPermitidos.ContainsKey(s.Campo))
            .Select(s => $"{camposPermitidos[s.Campo]} {(s.Valor?.ToUpper() == "DESC" ? "DESC" : "ASC")}")
            .ToList();
        
        if (validSorts.Count > 0)
            sql += " ORDER BY " + string.Join(", ", validSorts);
        else
            sql += " ORDER BY NOME ASC";
    }
    else
    {
        sql += " ORDER BY NOME ASC";
    }
    
    // Count total
    var filtrosSql = sql[sql.IndexOf("WHERE")..];
    var orderByIndex = filtrosSql.IndexOf("ORDER BY", StringComparison.OrdinalIgnoreCase);
    if (orderByIndex >= 0)
        filtrosSql = filtrosSql[..orderByIndex];
    
    var countSql = $"SELECT COUNT(*) FROM T_EMPRESA {filtrosSql}";
    var totalCount = await connection.ExecuteScalarAsync<int>(countSql, parameters);
    
    // Pagination
    sql += " OFFSET @Offset ROWS FETCH NEXT @PageSize ROWS ONLY";
    parameters.Add("Offset", (page - 1) * pageSize);
    parameters.Add("PageSize", pageSize);
    
    var items = await connection.QueryAsync<EmpresaListDTO>(sql, parameters);
    return new PaginatedList<EmpresaListDTO>(items.ToList(), totalCount, page, pageSize);
}
```

**Frontend Usage (Angular):**
```typescript
