### Command Handler Example
```csharp
public class CreateEmpresaCommandHandler(
    IMediator mediator, 
    IFileStorageService fileStorageService, 
    IEmpresaRepository empresaRepository, 
    ICurrentUserService currentUserService, 
    ILogService logService, 
    IUnitOfWork unitOfWork) 
    : IRequestHandler<CreateEmpresaCommand, ResponseBase<CreateEmpresaCommandResponse>>
{
    public async Task<ResponseBase<CreateEmpresaCommandResponse>> Handle(
        CreateEmpresaCommand request, 
        CancellationToken cancellationToken)
    {
        try
        {
            var dto = request.RequestDTO;
            
            // Business validation
            var existingCompany = await _empresaRepository.GetByCodigoIntegracaoAsync(
                dto.CodigoIntegracao, cancellationToken);
            
            if (existingCompany != null)
            {
                await _mediator.Publish(
                    new DomainNotification("Validation", "Código já existe."), 
                    cancellationToken);
                return ResponseBase<CreateEmpresaCommandResponse>.Failure();
            }
            
            // File upload
            string? logoFileName = null;
            if (dto.LogoEmpresa != null)
            {
                // Validate extension and size
                logoFileName = await _fileStorageService.SaveFileAsync(
                    dto.LogoEmpresa, "empresas", cancellationToken);
            }
            
            // Transaction
            await _unitOfWork.BeginTransactionAsync(cancellationToken);
            
            var empresa = new Empresa
            {
                NomeEmpresa = dto.NomeEmpresa,
                LogoEmpresa = logoFileName
            };
            
            await _empresaRepository.AddAsync(empresa, cancellationToken);
            await _unitOfWork.CommitAsync(cancellationToken);
            
            // Logging
            await _logService.Information(
                descricao: "Empresa cadastrada",
                detalhes: JsonSerializer.Serialize(new { empresa.Id, empresa.NomeEmpresa })
            );
            
            // Success notification
            await _mediator.Publish(
                new DomainSuccesNotification("Success", "Empresa cadastrada com sucesso."), 
                cancellationToken);
            
            return ResponseBase<CreateEmpresaCommandResponse>.Success(
                new CreateEmpresaCommandResponse
                {
                    Empresa = new CreateEmpresaResponseDTO
                    {
                        IdEmpresa = empresa.Id,
                        NomeEmpresa = empresa.NomeEmpresa
                    }
                });
        }
        catch (Exception ex)
        {
            if (_unitOfWork.HasTransactionOpen())
                await _unitOfWork.RollbackAsync(cancellationToken);
                
            await _logService.Error(
                descricao: "Erro ao cadastrar empresa",
                detalhes: ex.Message,
                exception: ex);
                
            await _mediator.Publish(
                new DomainNotification("Error", $"Erro: {ex.Message}"), 
                cancellationToken);
                
            return ResponseBase<CreateEmpresaCommandResponse>.Failure();
        }
    }
}
```

### Query Handler Example
```csharp
public class GetEmpresaByIdQueryHandler(
    IMediator mediator, 
    IEmpresaRepository empresaRepository, 
    IMapper mapper, 
    IFileStorageService fileStorageService) 
    : IRequestHandler<GetEmpresaByIdQuery, ResponseBase<GetEmpresaByIdQueryResponse>>
{
    public async Task<ResponseBase<GetEmpresaByIdQueryResponse>> Handle(
        GetEmpresaByIdQuery request, 
        CancellationToken cancellationToken)
    {
        try
        {
            var empresa = await _empresaRepository.GetByIdAsync(request.Id);
            
            if (empresa == null)
            {
                await _mediator.Publish(
                    new DomainNotification("NotFound", "Empresa não encontrada."), 
                    cancellationToken);
                return ResponseBase<GetEmpresaByIdQueryResponse>.Failure();
            }
            
            var empresaDto = _mapper.Map<EmpresaDTO>(empresa);
            
            // Return file as Base64 data URI
            if (!string.IsNullOrEmpty(empresa.LogoEmpresa))
            {
                empresaDto.LogoEmpresa = await _fileStorageService.GetFileAsBase64Async(
                    empresa.LogoEmpresa, "empresas", cancellationToken);
            }
            
            await _mediator.Publish(
                new DomainSuccesNotification("Success", "Empresa obtida com sucesso."), 
                cancellationToken);
            
            return ResponseBase<GetEmpresaByIdQueryResponse>.Success(
                new GetEmpresaByIdQueryResponse
                {
                    Empresa = empresaDto
                });
        }
        catch (Exception ex)
        {
            await _mediator.Publish(
                new DomainNotification("Error", $"Erro: {ex.Message}"), 
                cancellationToken);
            return ResponseBase<GetEmpresaByIdQueryResponse>.Failure();
        }
    }
}
```

